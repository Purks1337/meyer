---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="ru" class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon-green.svg" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  
  <!-- SEO Optimization -->
  <title>Стоматологические 3D-томографы Meyer — Официальное представительство в РФ</title>
  <meta name="description" content="Премиальные стоматологические 3D-томографы Meyer. Безупречная детализация снимков, ИИ-алгоритмы MyDentViewer, расширенная гарантия 4 года и бесплатный монтаж под ключ." />
  <meta name="keywords" content="3d томограф meyer, стоматологический томограф, клкт meyer, панорамный снимок зубов, цефалостат, MyDentViewer, стоматологическое оборудование" />
  
  <!-- Google Fonts Connection -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="bg-white text-slate-600 antialiased font-sans">

  <!-- ========================================================================= -->
  <!-- ШАПКА САЙТА (Header)                                                      -->
  <!-- ========================================================================= -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-slate-100 shadow-sm transition-all duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
      <!-- Логотип и дескриптор -->
      <div class="flex-shrink-0">
        <a href="#" class="flex flex-col items-start group">
          <img src="/logo.svg" alt="Meyer" class="h-8 sm:h-9 w-auto transition-transform group-hover:scale-[1.02]" />
          <span class="text-[8px] sm:text-[9px] text-slate-400 font-semibold tracking-wider uppercase leading-none mt-1.5 whitespace-nowrap">Официальный дистрибьютор в РФ</span>
        </a>
      </div>

      <!-- Меню навигации -->
      <nav class="hidden lg:flex items-center gap-6 xl:gap-8">
        <a href="#advantages" class="text-sm font-medium text-slate-600 hover:text-[#007457] transition-colors duration-200 whitespace-nowrap">Преимущества</a>
        <a href="#software" class="text-sm font-medium text-slate-600 hover:text-[#007457] transition-colors duration-200 whitespace-nowrap">MyDentViewer</a>
        <a href="#specs" class="text-sm font-medium text-slate-600 hover:text-[#007457] transition-colors duration-200 whitespace-nowrap">Характеристики</a>
        <a href="#faq" class="text-sm font-medium text-slate-600 hover:text-[#007457] transition-colors duration-200 whitespace-nowrap">FAQ</a>
      </nav>

      <!-- Контакты и CTA -->
      <div class="flex items-center gap-4 sm:gap-6 flex-shrink-0">
        <a href="tel:+79090272037" class="flex items-center gap-2 text-sm sm:text-base font-semibold text-slate-900 hover:text-[#007457] transition-colors whitespace-nowrap">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#007457] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span class="hidden sm:inline">+7 (909) 027-20-37</span>
        </a>
        <a href="#consultation" class="bg-[#007457] hover:bg-[#005a43] text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition-all duration-300 shadow-md shadow-[#007457]/10 hover:shadow-lg hover:shadow-[#007457]/20 active:scale-95 whitespace-nowrap">
          Нужна консультация
        </a>
      </div>
    </div>
  </header>

  <!-- ========================================================================= -->
  <!-- БЛОК 1: ГЛАВНЫЙ ЭКРАН (Hero Section)                                      -->
  <!-- ========================================================================= -->
  <section class="relative pt-12 pb-24 md:py-28 overflow-hidden bg-slate-50">
    <!-- Декоративные размытые круги -->
    <div class="absolute top-1/4 -left-32 w-96 h-96 bg-[#007457]/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-10 right-0 w-[500px] h-[500px] bg-[#007457]/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-[#007457]/10 text-[#007457] mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-[#007457] animate-pulse"></span>
        Стоматологическое 3D-оборудование
      </span>

      <div class="grid lg:grid-cols-12 gap-12 lg:gap-8 items-center lg:items-stretch">
        
        <!-- Текстовый контент (слева) -->
        <div class="lg:col-span-7 flex flex-col items-start">
          <h1 class="text-4xl sm:text-5xl lg:text-[56px] font-bold text-slate-900 tracking-tight leading-[1.1] mb-6">
            Стоматологические 3D-томографы <span class="text-[#007457]">Meyer</span>
          </h1>

          <p class="text-lg sm:text-xl text-slate-600 font-light leading-relaxed mb-8 max-w-2xl">
            Флагманское решение для точной диагностики. Безупречная детализация снимков, нейросетевые ИИ-алгоритмы и доказанная надежность — по оптимальной цене для вашей клиники.
          </p>

          <div class="flex flex-col sm:flex-row sm:items-center gap-6 mb-10 w-full sm:w-auto">
            <!-- Цена -->
            <div class="flex flex-col">
              <span class="text-sm font-semibold text-slate-400 uppercase tracking-wider">Стоимость</span>
              <span class="text-3xl font-extrabold text-slate-900 tracking-tight">по запросу</span>
            </div>
            <!-- CTA -->
            <a href="#lead-form" class="bg-[#007457] hover:bg-[#005a43] text-white px-8 py-4 rounded-full text-base font-semibold transition-all duration-300 shadow-xl shadow-[#007457]/15 hover:shadow-2xl hover:shadow-[#007457]/30 text-center hover:-translate-y-0.5 active:translate-y-0">
              Получить коммерческое предложение
            </a>
          </div>

          <!-- Спецпредложения (баннер) -->
          <div class="w-full bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
            <h3 class="text-base font-bold text-slate-900 mb-4 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#007457]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" />
              </svg>
              Рабочая станция и монтаж — в подарок!
            </h3>
            <p class="text-sm text-slate-500 mb-4">Инвестируйте в оборудование с максимальной выгодой:</p>
            <ul class="grid sm:grid-cols-2 gap-3">
              <li class="flex items-start gap-2.5 text-sm text-slate-700">
                <span class="text-[#007457] mt-0.5 font-bold">✓</span>
                <span><strong>Мощный ПК в комплекте:</strong> системный блок, монитор, клавиатура и мышь (гарантия 1 год).</span>
              </li>
              <li class="flex items-start gap-2.5 text-sm text-slate-700">
                <span class="text-[#007457] mt-0.5 font-bold">✓</span>
                <span><strong>Сборка в подарок:</strong> бесплатный монтаж и пусконаладка нашими инженерами.</span>
              </li>
              <li class="flex items-start gap-2.5 text-sm text-slate-700">
                <span class="text-[#007457] mt-0.5 font-bold">✓</span>
                <span><strong>Бесплатная доставка:</strong> до терминала ТК в вашем городе.</span>
              </li>
              <li class="flex items-start gap-2.5 text-sm text-slate-700 bg-emerald-50/50 p-1.5 rounded-lg border border-emerald-100/50">
                <span class="text-[#007457] mt-0.5">🔥</span>
                <span><strong>Расширенная гарантия:</strong> 4 года на томограф!</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Изображение и Рендер (справа) -->
        <div class="lg:col-span-5 relative flex justify-center lg:items-stretch">
          <div class="relative w-full max-w-md lg:max-w-none aspect-[4/5] lg:aspect-auto lg:h-full rounded-3xl overflow-hidden shadow-2xl border border-slate-100 bg-white p-6 flex flex-col justify-end items-center group">
            <div class="absolute inset-0 bg-radial-gradient from-transparent to-[#007457]/5 pointer-events-none"></div>
            <!-- Картинка томографа без фона -->
            <img src="/3d-tamograf.png" class="absolute inset-0 w-full h-full object-contain p-6 pb-28 transition-transform duration-700 group-hover:scale-105" alt="3D-томограф Meyer" />
            <!-- Информационный блок/плашка гарантии -->
            <div class="w-full bg-[#007457]/95 backdrop-blur-sm text-white p-4 rounded-xl flex items-center justify-between shadow-lg shadow-[#007457]/20 z-10">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-white/10 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                </div>
                <div>
                  <div class="text-[10px] text-emerald-200 font-bold uppercase tracking-wider">Официальная поддержка</div>
                  <div class="text-sm font-bold">4 года полной гарантии</div>
                </div>
              </div>
              <div class="text-xs bg-white/20 px-3 py-1 rounded-full font-semibold">
                Сертифицировано
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ========================================================================= -->
  <!-- БЛОК 2: ТЕХНОЛОГИИ И ПРЕИМУЩЕСТВА                                         -->
  <!-- ========================================================================= -->
  <section id="advantages" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Заголовок секции -->
      <div class="grid lg:grid-cols-12 gap-6 items-end mb-16">
        <div class="lg:col-span-7">
          <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 tracking-tight leading-tight">
            Инновации в каждой детали. Безупречное исполнение.
          </h2>
        </div>
        <div class="lg:col-span-5 lg:border-l lg:border-slate-100 lg:pl-8">
          <p class="text-lg text-slate-500 font-light">
            Продуманная эргономика для комфорта пациента и уверенности врача.
          </p>
        </div>
      </div>

      <!-- Уникальное позиционирование (широкая верхняя карточка) -->
      <div class="bg-gradient-to-br from-slate-50 to-emerald-50/30 rounded-3xl p-6 sm:p-8 border border-slate-100/60 shadow-sm flex flex-col md:flex-row items-center gap-8 mb-8">
        <div class="md:w-3/5">
          <span class="text-xs font-bold text-[#007457] uppercase tracking-wider mb-2 block">Уникальное позиционирование</span>
          <h3 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">5-точечная система фиксации пациента</h3>
          <p class="text-slate-600 leading-relaxed mb-6 font-light">
            Жесткая, но комфортная фиксация головы исключает случайные микродвижения во время сканирования. Больше никаких смазанных кадров и повторных облучений из-за двигательных артефактов.
          </p>
          <div class="flex flex-wrap gap-3 text-xs font-semibold text-slate-500">
            <span class="bg-white/80 backdrop-blur-sm border border-slate-200/60 px-3 py-1.5 rounded-lg flex items-center gap-1.5">
              <span class="text-[#007457] font-bold">✓</span> Исключает смазанные кадры
            </span>
            <span class="bg-white/80 backdrop-blur-sm border border-slate-200/60 px-3 py-1.5 rounded-lg flex items-center gap-1.5">
              <span class="text-[#007457] font-bold">✓</span> Безопасно и гигиенично
            </span>
            <span class="bg-white/80 backdrop-blur-sm border border-slate-200/60 px-3 py-1.5 rounded-lg flex items-center gap-1.5">
              <span class="text-[#007457] font-bold">✓</span> Повышенная точность КЛКТ
            </span>
          </div>
        </div>
        <div class="md:w-2/5 w-full rounded-2xl overflow-hidden bg-white p-3 border border-slate-100 shadow-sm">
          <img src="/positioning.png" class="w-full h-auto object-cover rounded-xl" alt="Система позиционирования головы пациента" />
        </div>
      </div>

      <!-- Сетка преимуществ 2x2 (снизу) -->
      <div class="grid lg:grid-cols-2 gap-6 mb-16">
        <!-- Карточка 1 -->
        <div class="bg-white p-6 sm:p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-all duration-300 group flex flex-col sm:flex-row gap-6 sm:items-start items-center">
          <div class="flex-1">
            <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center mb-5 transition-colors group-hover:bg-[#007457]/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#007457]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
              </svg>
            </div>
            <h4 class="text-lg font-bold text-slate-900 mb-2">Широкий выбор зон сканирования (FOV)</h4>
            <p class="text-sm text-slate-500 leading-relaxed font-light">
              Универсальные режимы под любые клинические задачи: от эндодонтии до имплантации (12x10 см, 15x10,5 см, 16x10 см, 17x11 см).
            </p>
          </div>
          <div class="w-full sm:w-1/3 flex-shrink-0 flex justify-center">
            <img src="/fov.webp" class="h-32 sm:h-36 w-auto object-contain rounded-lg" alt="Зоны сканирования FOV" />
          </div>
        </div>

        <!-- Карточка 2 -->
        <div class="bg-white p-6 sm:p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-all duration-300 group flex flex-col sm:flex-row gap-6 sm:items-start items-center">
          <div class="flex-1">
            <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center mb-5 transition-colors group-hover:bg-[#007457]/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#007457]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 8H17" />
              </svg>
            </div>
            <h4 class="text-lg font-bold text-slate-900 mb-2">Охват на 360 градусов</h4>
            <p class="text-sm text-slate-500 leading-relaxed font-light">
              Круговой алгоритм сканирования собирает максимум данных, эффективно подавляя теневые искажения и гарантируя кристально чистую картинку.
            </p>
          </div>
          <div class="w-full sm:w-1/3 flex-shrink-0 flex justify-center">
            <img src="/360.png" class="h-32 sm:h-36 w-auto object-contain rounded-lg" alt="Движение излучателя на 360" />
          </div>
        </div>

        <!-- Карточка 3 -->
        <div class="bg-white p-6 sm:p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-all duration-300 group flex flex-col sm:flex-row gap-6 sm:items-start items-center">
          <div class="flex-1">
            <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center mb-5 transition-colors group-hover:bg-[#007457]/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#007457]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h4 class="text-lg font-bold text-slate-900 mb-2">Интеллектуальное охлаждение трубки</h4>
            <p class="text-sm text-slate-500 leading-relaxed font-light">
              Аппарат готов к интенсивному потоку пациентов. Снимайте без длительных пауз на перегрев рентгеновского излучателя.
            </p>
          </div>
          <div class="w-full sm:w-1/3 flex-shrink-0 flex justify-center">
            <img src="/cooling.webp" class="h-32 sm:h-36 w-auto object-contain rounded-lg" alt="Интеллектуальное охлаждение" />
          </div>
        </div>

        <!-- Карточка 4 -->
        <div class="bg-white p-6 sm:p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition-all duration-300 group flex flex-col sm:flex-row gap-6 sm:items-start items-center">
          <div class="flex-1">
            <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center mb-5 transition-colors group-hover:bg-[#007457]/10">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#007457]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h4 class="text-lg font-bold text-slate-900 mb-2">Интерактивный дисплей</h4>
            <p class="text-sm text-slate-500 leading-relaxed font-light">
              Быстрая настройка параметров прямо на аппарате через интуитивно понятный сенсорный интерфейс.
            </p>
          </div>
          <div class="w-full sm:w-1/3 flex-shrink-0 flex justify-center">
            <img src="/screen.webp" class="h-32 sm:h-36 w-auto object-contain rounded-lg" alt="Дисплей на аппарате" />
          </div>
        </div>
      </div>

      <!-- Дополнительное преимущество: Цефалостат (широкая карточка внизу) -->
      <div class="bg-slate-50 rounded-3xl p-6 sm:p-10 border border-slate-100 shadow-sm flex flex-col md:flex-row items-center gap-8">
        <div class="md:w-1/3 rounded-2xl overflow-hidden bg-white p-4 border border-slate-100">
          <img src="/ceph.png" class="w-full h-auto object-cover rounded-xl" alt="Модуль цефалометрии" />
        </div>
        <div class="md:w-2/3">
          <span class="text-xs font-bold text-[#007457] uppercase tracking-wider mb-2 block">Ортодонтическое расширение</span>
          <h3 class="text-2xl font-bold text-slate-900 mb-4">Модуль цефалометрии (Ceph)</h3>
          <p class="text-slate-600 leading-relaxed mb-4 font-light">
            Опциональное плечо для создания высокоточных ТРГ-снимков — незаменимый инструмент врача-ортодонта. Съемка выполняется за минимальное время для предотвращения размытия из-за микродвижений.
          </p>
          <div class="flex flex-wrap gap-4 text-xs font-semibold text-slate-500">
            <span class="bg-white border border-slate-200 px-3 py-1.5 rounded-lg">Высокоскоростная ТРГ-съемка</span>
            <span class="bg-white border border-slate-200 px-3 py-1.5 rounded-lg">Минимальная лучевая нагрузка</span>
            <span class="bg-white border border-slate-200 px-3 py-1.5 rounded-lg">Правое или левое расположение</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ========================================================================= -->
  <!-- БЛОК 3: ИИ ТЕХНОЛОГИИ (Темный фон)                                        -->
  <!-- ========================================================================= -->
  <section class="py-24 bg-slate-900 text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(0,116,87,0.12),transparent_50%)] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-xs font-extrabold text-[#007457] uppercase tracking-wider mb-3 block">Интеллектуальные алгоритмы обработки</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white tracking-tight leading-tight">
          Нейросетевая обработка снимков для идеальной детализации
        </h2>
      </div>

      <div class="grid lg:grid-cols-12 gap-12 items-center">
        <!-- Интерактивный Before/After слайдер сравнения (слева) -->
        <div class="lg:col-span-7 flex flex-col items-center">
