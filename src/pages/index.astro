  <!-- КЛИЕНТСКИЙ СКРИПТ ДЛЯ ИНТЕРАКТИВА                                         -->
  <!-- ========================================================================= -->
  <script>
    // Перед-После ИИ-Слайдер в Блоке 3
    document.addEventListener('DOMContentLoaded', () => {
      const slider = document.getElementById('comparison-slider') as HTMLInputElement | null;
      const afterImage = document.getElementById('after-image') as HTMLImageElement | null;
      const sliderLine = document.getElementById('slider-line') as HTMLDivElement | null;

      if (slider && afterImage && sliderLine) {
        // Слушаем изменение значения ползунка
        slider.addEventListener('input', (e) => {
          const target = e.target as HTMLInputElement;
          const value = target.value;
          
          // В Tailwind clip-path inset(top, right, bottom, left)
          // Обрезаем изображение справа налево в соответствии с процентом ползунка
          // Если ползунок = 50%, left clip-path = 50%, показываем правую сторону
          afterImage.style.clipPath = `inset(0 0 0 ${value}%)`;
          sliderLine.style.left = `${value}%`;
        });
      }
    });
  </script>
